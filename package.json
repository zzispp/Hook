{
  "name": "hook-monorepo",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "bash scripts/dev-full.sh",
    "dev:frontend": "pnpm --filter hook_frontend dev",
    "build:frontend": "pnpm --filter hook_frontend build",
    "build:frontend:embedded": "BUILD_STATIC_EXPORT=true pnpm --filter hook_frontend build",
    "lint:frontend": "pnpm --filter hook_frontend lint",
    "dev:backend": "cargo run -p hook_backend",
    "check:backend": "cargo check -p hook_backend",
    "build:backend": "cargo build -p hook_backend",
    "build:backend:embedded": "pnpm build:frontend:embedded && cargo build -p hook_backend --release",
    "start:embedded": "pnpm build:frontend:embedded && cargo run -p hook_backend"
  },
  "pnpm": {
    "packageExtensions": {
      "@hookform/resolvers": {
        "peerDependencies": {
          "zod": "*"
        }
      }
    },
    "overrides": {
      "cuer@0.0.3>qr": "0.5.5"
    }
  }
}
